@startuml
left to right direction
skinparam shadowing false
skinparam packageStyle rectangle
skinparam actorStyle awesome
skinparam backgroundColor white
skinparam ArrowColor #5B657A
skinparam UsecaseBackgroundColor #F9FBFD
skinparam UsecaseBorderColor #5B657A

title NutriCare - Use Case Quan Ly San Pham

actor "Nhan vien\nvan hanh" as Staff
actor "Quan tri vien" as Admin

Staff <|-- Admin

rectangle "Phan he quan ly san pham" #EAF1FF {
  usecase "Xem danh sach san pham" as UC_ListProducts
  usecase "Them san pham moi" as UC_CreateProduct
  usecase "Cap nhat san pham" as UC_UpdateProduct
  usecase "Xoa san pham" as UC_DeleteProduct
  usecase "Tai anh san pham" as UC_UploadImage
  usecase "Cap nhat badge /\nkhuyen mai / noi bat" as UC_UpdatePromotion
}

Staff --> UC_ListProducts
Staff --> UC_CreateProduct
Staff --> UC_UpdateProduct
Staff --> UC_DeleteProduct

UC_CreateProduct ..> UC_UploadImage : <<extend>>
UC_UpdateProduct ..> UC_UploadImage : <<extend>>
UC_CreateProduct ..> UC_UpdatePromotion : <<extend>>
UC_UpdateProduct ..> UC_UpdatePromotion : <<extend>>
@enduml
