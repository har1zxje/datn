@startuml
left to right direction
skinparam shadowing false
skinparam packageStyle rectangle
skinparam actorStyle awesome
skinparam backgroundColor white
skinparam ArrowColor #5B657A
skinparam UsecaseBackgroundColor #F9FBFD
skinparam UsecaseBorderColor #5B657A

title NutriCare - Use Case Van Hanh Danh Cho Staff

actor "Nhan vien van hanh" as Staff

rectangle "Phan he van hanh staff" #EAF1FF {
  usecase "Quan ly san pham" as UC_ManageProducts
  usecase "Them / sua / xoa\nsan pham" as UC_ProductCrud
  usecase "Quan ly don hang" as UC_ManageOrders
  usecase "Xem chi tiet don hang" as UC_OrderDetail
  usecase "Cap nhat trang thai don" as UC_UpdateOrderStatus
  usecase "Cap nhat trang thai hang loat" as UC_BulkUpdateStatus
  usecase "Quan ly kho" as UC_ManageStock
  usecase "Nhap / xuat kho\nthu cong" as UC_StockTransaction
  usecase "Import Excel kho" as UC_ImportStockExcel
  usecase "Export Excel kho" as UC_ExportStockExcel
}

Staff --> UC_ManageProducts
Staff --> UC_ManageOrders
Staff --> UC_ManageStock

UC_ManageProducts ..> UC_ProductCrud : <<include>>
UC_ManageOrders ..> UC_OrderDetail : <<include>>
UC_ManageOrders ..> UC_UpdateOrderStatus : <<include>>
UC_ManageOrders ..> UC_BulkUpdateStatus : <<include>>
UC_ManageStock ..> UC_StockTransaction : <<include>>
UC_ManageStock ..> UC_ImportStockExcel : <<include>>
UC_ManageStock ..> UC_ExportStockExcel : <<include>>
@enduml
