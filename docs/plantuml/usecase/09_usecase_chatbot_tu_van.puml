@startuml
left to right direction
skinparam shadowing false
skinparam packageStyle rectangle
skinparam actorStyle awesome
skinparam backgroundColor white
skinparam ArrowColor #5B657A
skinparam UsecaseBackgroundColor #F9FBFD
skinparam UsecaseBorderColor #5B657A

title NutriCare - Use Case Chatbot Tu Van

actor "Nguoi dung\n(chua dang nhap)" as Guest
actor "Nguoi dung\n(da dang nhap)" as Member
actor "n8n workflow /\nAI assistant" as ChatEngine

rectangle "Phan he chatbot tu van" #EAF7EE {
  usecase "Mo widget chat" as UC_OpenChat
  usecase "Hoi dap ve don hang /\nvan chuyen / nau an" as UC_AskChat
  usecase "Dung quick actions" as UC_QuickAction
  usecase "Goi y san pham\nphu hop" as UC_SuggestProducts
  usecase "Gui user context\n& danh muc san pham" as UC_SendContext
}

Guest --> UC_OpenChat
Guest --> UC_AskChat
Member --> UC_OpenChat
Member --> UC_AskChat
ChatEngine --> UC_AskChat

UC_AskChat ..> UC_QuickAction : <<extend>>
UC_AskChat ..> UC_SendContext : <<include>>
UC_AskChat ..> UC_SuggestProducts : <<extend>>
@enduml
