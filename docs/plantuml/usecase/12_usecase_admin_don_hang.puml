@startuml
left to right direction
skinparam shadowing false
skinparam packageStyle rectangle
skinparam actorStyle awesome
skinparam backgroundColor white
skinparam ArrowColor #5B657A
skinparam UsecaseBackgroundColor #F9FBFD
skinparam UsecaseBorderColor #5B657A

title NutriCare - Use Case Quan Ly Don Hang

actor "Nhan vien\nvan hanh" as Staff
actor "Quan tri vien" as Admin

Staff <|-- Admin

rectangle "Phan he quan ly don hang" #EAF1FF {
  usecase "Xem danh sach don hang" as UC_ListOrders
  usecase "Tim kiem / loc /\nphan trang don hang" as UC_FilterOrders
  usecase "Xem chi tiet don hang" as UC_OrderDetail
  usecase "Cap nhat trang thai tung don" as UC_UpdateOrderStatus
  usecase "Cap nhat trang thai\nhang loat" as UC_BulkStatus
  usecase "Xoa don hang" as UC_DeleteOrder
}

Staff --> UC_ListOrders
Staff --> UC_OrderDetail
Staff --> UC_UpdateOrderStatus
Staff --> UC_BulkStatus
Admin --> UC_DeleteOrder

UC_ListOrders ..> UC_FilterOrders : <<include>>
UC_ListOrders ..> UC_OrderDetail : <<extend>>
@enduml
