@startuml
title FE-BE Connection (As-Is)
skinparam shadowing false
skinparam linetype ortho

actor User
participant "Frontend (Browser)\nAPI_BASE_URL from VITE_API_BASE_URL" as FE
participant "FastAPI Backend :8001\n/api/*" as BE
participant "Auth API\n/api/auth/refresh" as Refresh
participant "Scan API\n/api/scans/quick-analyze" as Scan

User -> FE : Mo web / thao tac chuc nang
FE -> BE : HTTP /api/*\n(axios baseURL)
BE --> FE : JSON response

alt access_token het han (401)
  FE -> Refresh : POST refresh_token
  Refresh --> FE : access_token moi
  FE -> BE : retry request voi Bearer moi
end

FE -> Scan : POST quick-analyze(form-data)
Scan --> FE : freshness_level, ai_confidence,\nneeds_manual_review, spoilage_ratio_pct

FE -> BE : POST /api/scans/feedback-events
BE --> FE : saved

note right of BE
CORS allow origins mac dinh:
localhost:3000, 3001, 5173
end note

@enduml
